// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
generator py {
  provider             = "prisma-client-py"
  interface            = "sync"
  recursive_type_depth = 5
}

model Stratagems {
  id       String @id @default(cuid())
  urlImage String
  name     String
  type     String
}

model Guns {
  id       String  @id @default(cuid())
  gunImage String
  name     String
  type     String
  class    String
}

model Booster {
  id           String @id @default(cuid())
  boosterImage String
  name         String
}
